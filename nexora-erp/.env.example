# ==========================================
# NEXORA ERP - Variáveis de Ambiente
# ==========================================
# Copie este ficheiro para .env e preencha os valores
# cp .env.example .env
# ==========================================

# ------------------------------------------
# Ambiente
# ------------------------------------------
NODE_ENV=production

# ------------------------------------------
# JWT (JSON Web Token) - CRÍTICO: Use segredos fortes!
# ------------------------------------------
# Segredo para tokens de acesso (gerar com: openssl rand -base64 64)
JWT_SECRET=
# Segredo para tokens de refresh (gerar com: openssl rand -base64 64)
JWT_REFRESH_SECRET=
# Tempo de expiração do token de acesso (ex: 15m, 1h)
JWT_EXPIRES_IN=15m
# Tempo de expiração do token de refresh (ex: 7d, 30d)
JWT_REFRESH_EXPIRES_IN=7d

# ------------------------------------------
# PostgreSQL - Base de Dados Principal
# ------------------------------------------
DB_NAME=nexora_erp
DB_USER=
DB_PASSWORD=

# ------------------------------------------
# Redis - Cache e Sessões
# ------------------------------------------
REDIS_PASSWORD=

# ------------------------------------------
# RabbitMQ - Message Broker
# ------------------------------------------
RABBITMQ_USER=
RABBITMQ_PASS=

# ------------------------------------------
# CORS - Controle de Origem
# ------------------------------------------
# URLs permitidos (separados por vírgula)
# Para produção: use o domínio principal
CORS_ORIGIN=https://nexora-erp.e258tech.tech

# ------------------------------------------
# Traefik - API Gateway Dashboard
# ------------------------------------------
# Credenciais para aceder ao dashboard (gerar com: htpasswd -nb admin senha)
TRAEFIK_DASHBOARD_USER=admin
TRAEFIK_DASHBOARD_PASSWORD=

# ------------------------------------------
# Notifications Service - Email (SMTP)
# ------------------------------------------
# Servidor SMTP para envio de emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@nexoraerp.com

# ------------------------------------------
# Notifications Service - AWS SES (Alternativa ao SMTP)
# ------------------------------------------
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SES_FROM=noreply@nexoraerp.com

# ------------------------------------------
# Notifications Service - WhatsApp Business API
# ------------------------------------------
WHATSAPP_BUSINESS_PHONE_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v19.0

# ------------------------------------------
# Notifications Service - Evolution API (WhatsApp)
# ------------------------------------------
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=nexora-erp

# ------------------------------------------
# Notifications Service - SMS (SMPP)
# ------------------------------------------
SMPP_HOST=
SMPP_PORT=2775
SMPP_SYSTEM_ID=
SMPP_PASSWORD=
SMPP_SYSTEM_TYPE=
SMPP_SOURCE_ADDR=NEXORA
SMPP_SOURCE_TON=5
SMPP_SOURCE_NPI=0
SMPP_DEST_TON=1
SMPP_DEST_NPI=1
