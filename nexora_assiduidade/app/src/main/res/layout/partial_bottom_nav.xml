<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/bottomNav"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/surface"
    android:orientation="horizontal"
    android:elevation="6dp"
    android:paddingTop="1dp">

    <LinearLayout
        android:id="@+id/navHome"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <ImageView
            android:id="@+id/navHomeIcon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="Início"
            android:src="@drawable/ic_nav_home" />

        <TextView
            android:id="@+id/navHomeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Início"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/navModules"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <ImageView
            android:id="@+id/navModulesIcon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="Módulos"
            android:src="@drawable/ic_nav_modules" />

        <TextView
            android:id="@+id/navModulesLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Módulos"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/navChat"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <ImageView
            android:id="@+id/navChatIcon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="Chat"
            android:src="@drawable/ic_nav_chat" />

        <TextView
            android:id="@+id/navChatLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Chat"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/navVacation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <ImageView
            android:id="@+id/navVacationIcon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="Férias"
            android:src="@drawable/ic_nav_vacation" />

        <TextView
            android:id="@+id/navVacationLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Férias"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/navAttendance"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <ImageView
            android:id="@+id/navAttendanceIcon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="Assiduidade"
            android:src="@drawable/ic_nav_attendance" />

        <TextView
            android:id="@+id/navAttendanceLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Assiduidade"
            android:textSize="10sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/navProfile"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <ImageView
            android:id="@+id/navProfileIcon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="Perfil"
            android:src="@drawable/ic_nav_profile" />

        <TextView
            android:id="@+id/navProfileLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Perfil"
            android:textSize="11sp" />
    </LinearLayout>

</LinearLayout>
