{
  "info": {
    "name": "Nexora ERP — API Completa",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base", "value": "http://localhost:8080" },
    { "key": "token", "value": "" },
    { "key": "refresh_token", "value": "" },
    { "key": "tenant_id", "value": "" }
  ],
  "item": [
    {
      "name": "🔍 Health",
      "item": [
        {
          "name": "Health Check",
          "request": { "method": "GET", "url": "{{base}}/health" }
        }
      ]
    },
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": [
            "var j = pm.response.json();",
            "if(j.token) pm.collectionVariables.set('token', j.token);",
            "if(j.refresh_token) pm.collectionVariables.set('refresh_token', j.refresh_token);"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{base}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@empresa.co.mz\",\n  \"password\": \"senha123\"\n}" }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{base}}/api/auth/refresh",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}" }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "url": "{{base}}/api/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Meu Acesso (RBAC)",
          "request": {
            "method": "GET",
            "url": "{{base}}/api/auth/me/acesso",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{base}}/api/auth/logout",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Mudar Password",
          "request": {
            "method": "POST",
            "url": "{{base}}/api/auth/change-password",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"password_atual\": \"senha123\",\n  \"password_nova\": \"novaSenha456\"\n}" }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "url": "{{base}}/api/auth/forgot-password",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"user@empresa.co.mz\"\n}" }
          }
        }
      ]
    },
