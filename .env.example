# ── Base de dados ──────────────────────────────────────────────
DATABASE_URL=postgres://postgres:PASSWORD@CONTAINER_POSTGRES:5432/nexora_erp?sslmode=disable

# ── JWT ────────────────────────────────────────────────────────
JWT_SECRET=change-me-jwt-secret-32chars-min
JWT_REFRESH_SECRET=change-me-refresh-secret-32chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Servidor ───────────────────────────────────────────────────
PORT=8080
APP_ENV=production
CORS_ORIGIN=https://nexora.e258tech.tech

# ── Ficheiros / Uploads ────────────────────────────────────────
AVATAR_DIR=./avatars
AVATAR_MAX_MB=2
UPLOADS_DIR=./uploads
UPLOAD_MAX_MB=3

# ── Recrutamento ───────────────────────────────────────────────
# Fallback: tenant usado quando o Host do pedido não identifica nenhum tenant
# (ex.: portal partilhado, localhost em dev). Nos domínios e subdomínios de
# tenant o Host manda e este valor é ignorado.
RECRUITMENT_TENANT_ID=1

# ── Multi-tenant ───────────────────────────────────────────────
# Domínio base da plataforma: um pedido a <codigo>.<PLATFORM_BASE_DOMAIN>
# resolve para o tenant com esse código, sem precisar de registo em
# saas.tenant_dominios. Vazio = só domínios próprios resolvem.
PLATFORM_BASE_DOMAIN=nexora.e258tech.tech

# ── SMTP — envio de emails transaccionais ──────────────────────
# Deixar SMTP_HOST vazio desactiva o envio (notificações ficam em 'pendente')
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=no-reply@nexora.mz
SMTP_PASSWORD=change-me-smtp-password
SMTP_FROM=no-reply@nexora.mz
SMTP_FROM_NAME=Nexora ERP

# ── Pagamentos — gateway webhook ────────────────────────────────
# Segredo HMAC-SHA256 para validar callbacks do gateway de pagamento.
GATEWAY_WEBHOOK_SECRET=change-me-webhook-secret-32chars

# ── Nexora-Pay — Gateway M-Pesa / eMola / mKesh ─────────────────
# URL do nexora-pay (servico externo independente, ex: https://pay.e258tech.tech)
NEXORA_PAY_BASE_URL=https://pay.e258tech.tech
# API key: cd D:\projecto\e-258tech\2026\nexora-pay\backend && ./gatewayctl client create "Nexora ERP" 171717
NEXORA_PAY_API_KEY=e258_change-me
# Service account: ./gatewayctl service-account create <CLIENT_ID> gestao-escolar 171717 "Gestao Escolar" pagamentos@escola.mz
NEXORA_PAY_SERVICE_ACCOUNT=gestao-escolar
