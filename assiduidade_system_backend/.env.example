APP_NAME=FaceClock API
APP_VERSION=1.0.0
DATABASE_URL=sqlite:///./faceclock.db
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
BIOMETRIC_QUALITY_THRESHOLD=0.55
BIOMETRIC_LIVENESS_THRESHOLD=0.60
BIOMETRIC_MATCH_THRESHOLD=0.85
SEED_DATA_ON_STARTUP=false
DOCS_URL=/docs
OPENAPI_URL=/openapi.json

# External payroll integration
PAYROLL_PROVIDER_BASE_URL=
PAYROLL_PROVIDER_API_KEY=
PAYROLL_PROVIDER_TIMEOUT_SECONDS=30

# ERP Omnisys integration
ERP_BASE_URL=http://localhost:8080
ERP_API_KEY=
ERP_TIMEOUT_SECONDS=10
# Allow local demo login when ERP is unreachable (development only)
ERP_FALLBACK_LOCAL_LOGIN=true

# Adjustment review auto-correction
AUTO_CORRECT_ON_APPROVAL=true

# Notifications
# EMAIL_PROVIDER=aws_ses usa a API da AWS via boto3.
# EMAIL_PROVIDER=smtp mantem o envio via SMTP tradicional.
EMAIL_PROVIDER=aws_ses
AWS_SES_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_SES_FROM=no-reply@your-verified-domain.com
AWS_SES_REPLY_TO=
AWS_SES_CONFIGURATION_SET=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@your-verified-domain.com
SMS_API_KEY=
SMS_API_URL=
NOTIFICATION_WEBHOOK_URL=

# SSO / OIDC
OIDC_ENABLED=false
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:8000/api/v1/auth/oidc/callback
OIDC_SCOPES=openid email profile
OIDC_ADMIN_ROLES=ADMIN,GESTOR

# Data Retention (days)
RETENTION_CLOCK_RECORDS_DAYS=1825
RETENTION_AUDIT_LOGS_DAYS=3650
RETENTION_INTEGRATION_BATCHES_DAYS=90
