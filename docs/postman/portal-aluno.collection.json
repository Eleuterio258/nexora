  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Guarda automaticamente o access_token após login",
          "if (pm.request.url.path.join('/').includes('login') && pm.response.code === 200) {",
          "    const json = pm.response.json();",
          "    if (json.access_token) {",
          "        pm.collectionVariables.set('access_token', json.access_token);",
          "    }",
          "}"
        ]
      }
    }
  ],
  "variable": [
