<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="16dp">

    <View
        android:id="@+id/vActivityDot"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:background="@drawable/bg_dot_active" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvActivityTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Factura #FT-2024-0038"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvActivitySub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Cliente: Empresa ABC"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvActivityAmount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="12.500 MT"
        android:textColor="@color/text_primary"
        android:textSize="13sp"
        android:textStyle="bold" />

</LinearLayout>
