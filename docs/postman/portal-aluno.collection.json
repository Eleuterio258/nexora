{
  "info": {
    "_postman_id": "nexora-portal-aluno-001",
    "name": "Nexora ERP - Portal do Aluno",
    "description": "Collection das rotas do portal de auto-serviço do aluno. Todas as rotas autenticadas usam o token obtido em `Login`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Autenticação",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/portal/aluno/login",
              "host": ["{{base_url}}"],
              "path": ["api", "portal", "aluno", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"aluno.teste@nexora.test\",\n  \"password\": \"outrasenha456\"\n}"
            },
            "description": "Autentica o aluno em auth.users e devolve o access_token do portal."
          },
          "response": []
        },
        {
          "name": "Definir Senha (convite)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/portal/aluno/definir-senha",
              "host": ["{{base_url}}"],
              "path": ["api", "portal", "aluno", "definir-senha"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"token_do_convite_aqui\",\n  \"password\": \"nova_senha_123\"\n}"
            },
            "description": "Primeiro acesso via link de convite."
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/portal/aluno/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "portal", "aluno", "logout"]
            },
            "description": "Revoga a sessão actual do aluno."
          },
          "response": []
        }
      ]
    },
